# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Model Configuration
# Specify which OpenAI model to use (e.g., gpt-4, gpt-3.5-turbo)
OPENAI_MODEL=gpt-3.5-turbo

# Temperature Setting (0.0 - 2.0)
# Lower values make output more focused and deterministic
# Higher values make output more random and creative
TEMPERATURE=0.0

# Agent Configuration
# Maximum number of iterations the agent can perform
MAX_ITERATIONS=10

# Verbose Mode (true/false)
# Set to true to see detailed agent reasoning steps
VERBOSE=true
